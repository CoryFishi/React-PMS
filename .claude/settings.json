{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git config --get:*)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat package.json)",
      "Bash(cd client)",
      "Bash(cd server)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run build)",
      "Bash(npm run build:*)",
      "Bash(npm run preview)",
      "Bash(npm run dev)",
      "Bash(npm ls:*)",
      "Bash(npm view:*)",
      "Bash(node --version)",
      "Bash(node -v)",
      "Bash(npm --version)",
      "Bash(npm -v)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)"
    ],
    "deny": [
      "Read(./server/.env)",
      "Read(./server/.env.*)",
      "Read(./client/.env)",
      "Read(./client/.env.*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(npm publish:*)"
    ]
  }
}
