# Copy to server/.env and fill in real values. Never commit server/.env.

# --- Core ---
MONGO_URL=mongodb://localhost:27017/react-pms
PORT=3000
JWT_SECRET=replace-with-a-long-random-string
API_KEY=replace-with-shared-api-key-for-integrations
FRONTEND_URL=http://localhost:5173

# --- Email (Nodemailer) ---
EMAIL=your-smtp-user@example.com
PASS=your-smtp-password-or-app-password

# --- Stripe ---
# Both names are read by different services; set both to the same secret key.
STRIPE_SECRET=sk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me

# --- DocuSign (JWT auth) ---
DS_ACCOUNT_ID=your-docusign-account-guid
DS_BASE_PATH=https://demo.docusign.net/restapi
DS_INTEGRATION_KEY=your-integration-key-guid
DS_OAUTH_BASE=account-d.docusign.com
DS_USER_ID=your-impersonated-user-guid
# Base64-encoded RSA private key (the body between the BEGIN/END lines, base64-encoded).
DS_PRIVATE_KEY_B=base64-encoded-rsa-private-key
